{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "手动调试 PyClangd",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}"
            ],
            "outFiles": [
                "${workspaceFolder}/out/**/*.js"
            ],
            "preLaunchTask": "npm: compile"
        },
        {
            "name": "🐍 调试 Python: test_engine.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/server/test/test_engine.py",
            "python": "/home/lc/.pyenv/versions/py-clangd-env/bin/python",
            "subProcess": true,
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/server/test"
        },
        {
            "name": "🐍 调试 Python: 当前打开的文件",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "python": "/home/lc/.pyenv/versions/py-clangd-env/bin/python",
            "subProcess": true,
            "console": "integratedTerminal",
            "cwd": "${fileDirname}"
        }
    ]
}